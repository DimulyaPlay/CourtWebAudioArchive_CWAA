# An .aiignore file follows the same syntax as a .gitignore file.
# .gitignore documentation: https://git-scm.com/docs/gitignore

# you can ignore files
.DS_Store
*.log
*.tmp
*.spec
*.exe
*.txt
*.db
batches_*
app.log

# or folders
dist/
build/
out/
frontend/assets/
.venv/
__pycache__/
*.pyc
.idea/
.git/
temp/
nginx/